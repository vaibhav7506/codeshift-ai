# Optional for the web analyzer. Public repository analysis works without a
# token, but authenticated requests receive a higher GitHub API rate limit.
# The CLI PR flow reads GITHUB_TOKEN from its shell and requires repository
# contents and pull request write access. Never commit a real token.
GITHUB_TOKEN=

# CLI-only BYOK variables. Set these in your shell before running the CLI.
# Never prefix provider keys with NEXT_PUBLIC_ or commit real values.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
GROQ_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
